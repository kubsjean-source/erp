# Supabase 연결 정보 (참고용 템플릿)
#
# 현재 index.html은 정적 파일이라 빌드 단계가 없으므로 이 .env는 직접 읽히지 않습니다.
# 키 값은 index.html 상단의 SUPABASE_URL / SUPABASE_PUBLISHABLE_KEY 상수에 직접 넣으세요.
#
# 추후 빌드 도구(Vite 등) 도입 시 이 파일이 그대로 활용됩니다.

# Supabase 프로젝트 URL — Settings → API → Project URL
SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Publishable key — Settings → API → Project API keys → publishable (sb_publishable_*)
# RLS 기반 읽기 전용 클라이언트용. 절대 service_role 키를 넣지 마세요.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
